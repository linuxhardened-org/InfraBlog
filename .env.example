# --- Database Configuration ---
# You can choose between a local PostgreSQL (Docker) or a managed Supabase project.

# Option 1: Supabase (Recommended for Production & Easy Setup)
# Get these from: Supabase Project Settings > Database > Connection Strings
# Use the "Transaction" (pooled) URL for DATABASE_URL (usually port 6543)
# Use the "Session" (direct) URL for DIRECT_URL (usually port 5432)
DATABASE_URL=postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true
DIRECT_URL=postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres

# Option 2: Local PostgreSQL (using docker-compose)
# If using Option 1, comment these out.
# POSTGRES_USER=infrablog
# POSTGRES_PASSWORD=infrablog_secret
# POSTGRES_DB=infrablog
# DATABASE_URL=postgresql://infrablog:infrablog_secret@localhost:5432/infrablog
# DIRECT_URL=postgresql://infrablog:infrablog_secret@localhost:5432/infrablog

# --- Supabase Extras (Optional: for Auth/Storage integration) ---
# SUPABASE_URL=https://[PROJECT_REF].supabase.co
# SUPABASE_ANON_KEY=[YOUR_ANON_KEY]
# SUPABASE_SERVICE_ROLE_KEY=[YOUR_SERVICE_ROLE_KEY]

# --- Other Services ---
# Redis (Local or managed)
REDIS_URL=redis://localhost:6379

# JWT Secret (IMPORTANT: Change this to a secure random string)
JWT_SECRET=super_secret_jwt_key_change_in_production

# --- Backend Config ---
PORT=3001
NODE_ENV=development
UPLOAD_DIR=./uploads

# --- Frontend Config ---
NEXT_PUBLIC_API_URL=http://localhost:3001/api
INTERNAL_API_URL=http://localhost:3001/api
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_SITE_NAME=InfraBlog

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000
