# Database (Local PostgreSQL)
POSTGRES_USER=infrablog
POSTGRES_PASSWORD=infrablog_secret
POSTGRES_DB=infrablog
DATABASE_URL=postgresql://infrablog:infrablog_secret@localhost:5432/infrablog
DIRECT_URL=postgresql://infrablog:infrablog_secret@localhost:5432/infrablog

# Supabase (uncomment and replace above DATABASE_URL/DIRECT_URL if using Supabase)
# DATABASE_URL=postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true
# DIRECT_URL=postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=super_secret_jwt_key_change_in_production

# Backend
PORT=3001
NODE_ENV=development
UPLOAD_DIR=./uploads

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:3001/api
INTERNAL_API_URL=http://localhost:3001/api
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_SITE_NAME=InfraBlog

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000
